{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:zod.dev)",
      "WebSearch",
      "Glob",
      "Bash(ctx7 *)",
      "Bash(jq *)",
      "Bash(rg *)",
      "Bash(wc -l *)",
      "Bash(npx tsc*)",
      "Bash(pnpm test*)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(**/.env)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ty/.claude/hooks/block-bin-rm.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ty/.claude/hooks/block-git-push.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/ty/.claude/hooks/prefer-modern-cli.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ty/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/ty/.dotfiles/claude/scripts/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "playground@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ccx@ty": true,
    "skill-lab@ty": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ty": {
      "source": {
        "source": "directory",
        "path": "/Users/ty/.dotfiles/claude"
      }
    }
  },
  "voiceEnabled": true,
  "autoDreamEnabled": true,
  "effortLevel": "high"
}
